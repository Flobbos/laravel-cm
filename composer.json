{
    "name": "flobbos/laravel-cm",
    "version": "6.2.2",
    "description": "Complete package for Campaign Monitor integration",
    "keywords": [
        "laravel",
        "newsletter",
        "campaign-monitor"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Alexej Krzewitzki",
            "email": "alexej@helloo.it",
            "homepage": "http://helloo.it"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "11.*|12.*|13.*",
        "guzzlehttp/guzzle": "^7.4",
        "maatwebsite/excel": "^3.1"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Flobbos\\LaravelCM\\LaravelCMServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Flobbos\\LaravelCM\\": "src/LaravelCM/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Flobbos\\LaravelCM\\Tests\\": "tests/",
            "App\\Models\\": "src/LaravelCM/Models/",
            "App\\Http\\Controllers\\": "tests/stubs/"
        }
    },
    "scripts": {
        "test": "@php vendor/bin/pest"
    },
    "require-dev": {
        "pestphp/pest": "^3.0 || ^4.0",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
